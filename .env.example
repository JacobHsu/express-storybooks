# ── 伺服器 ──────────────────────────────────
# 伺服器埠號（選填，預設 3000）
PORT=3000

# ── MongoDB Atlas（雲端資料庫，必填）────────────
# 格式：mongodb+srv://<帳號>:<密碼>@<cluster>.mongodb.net/<資料庫名>?retryWrites=true&w=majority
# 取得方式見 readme「一、MongoDB Atlas（雲端資料庫）」。
# 注意：密碼若含特殊字元需 URL encode（例：@ → %40、# → %23）。
MONGO_URI=mongodb+srv://appuser:YourStrongPwd@cluster0.xxxxx.mongodb.net/storybooks?retryWrites=true&w=majority

# 若改用本機 MongoDB，改成下面這行：
# MONGO_URI=mongodb://127.0.0.1:27017/storybooks

# 若 mongodb+srv 出現 "querySrv ECONNREFUSED"（部分 ISP DNS 不支援 SRV 查詢），
# 取消下行註解，指定備用 DNS 解析伺服器：
# DNS_SERVERS=8.8.8.8,1.1.1.1

# ── Google OAuth 2.0（第三方登入，必填）──────────
# 取得方式見 readme「二、Google Cloud OAuth（第三方登入）」。
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ── Session 加密金鑰（必填）────────────────────
# 用於簽署 session cookie，請填入 32 字元以上的隨機字串。
# 產生方式（任選其一）：
#   Node:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OpenSSL: openssl rand -hex 32
# ⚠️ 切勿與他人共用、切勿 commit 到 repo。外洩需立即更換。
SESSION_SECRET=replace_me_with_a_long_random_string

# ── 開發用快速登入後門（選填）──────────────────
# 設為 true 時，可用 http://localhost:3000/auth/dev 繞過 Google 直接登入。
# ⚠️ 正式環境務必留空或設為 false。
ALLOW_DEV_LOGIN=
